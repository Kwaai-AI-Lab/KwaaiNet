    P12 -->|"text chunks"| P14
    P12 -->|"text chunks"| P15
    P12 -->|"text chunks"| P19
    P13 -->|"entity extraction prompt"| LLM
    LLM -->|"entities"| P13
    P13 -->|"named entities"| P18
    P14 -->|"chunk + section metadata"| MDB
    P15 -->|"chunk text"| VDB
    P15 -->|"token stream"| BM25
    P16 -->|"relation extraction prompt"| LLM
    LLM -->|"relations"| P16
